# ============================================
# ATPlan AI旅行规划系统 - 环境变量配置模板
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改 .env 文件中的敏感配置（API Key等）
# 3. 确保 .env 已加入 .gitignore，不要提交到版本控制
# ============================================

# ============================================
# 数据库配置 (MySQL)
# ============================================
MYSQL_ROOT_PASSWORD=change-me
MYSQL_PASSWORD=change-me

# ============================================
# 缓存配置 (Redis)
# 本地第一阶段默认留空，避免 Redis 健康检查需要认证
# ============================================
REDIS_PASSWORD=

# ============================================
# LLM API配置 (阿里灵积平台 - DashScope)
# 获取地址: https://dashscope.aliyun.com/
# ============================================
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# 百度地图MCP配置
# 用于路线规划的真实地图数据
# ============================================
BAIDU_MCP_URL=https://agent-http.baidu.com/mcp/nmap-mcp/nmap-mcp-server

# ============================================
# Nacos配置
# ============================================
NACOS_SERVER_ADDR=nacos:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=change-me
NACOS_AUTH_TOKEN=change-me
